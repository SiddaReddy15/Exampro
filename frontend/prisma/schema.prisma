generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Question {
  id            String   @id @default(uuid())
  category      String
  type          QuestionType
  title         String?
  questionText  String
  options       Json?
  correctAnswer String?
  difficulty    String
  marks         Int
  languages     String?
  testCases     Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("questions")
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  password     String
  role         String    @default("STUDENT")
  status       String?   @default("VERIFIED")
  profilePhoto String?   @map("profile_photo")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("users")
}

enum QuestionType {
  MCQ
  CODING
}
